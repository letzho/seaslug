# WebSocket URL for mqtt.js in the browser (not tcp://1883).
# mqttgo.io (cloud): use mqttgo.io host, NOT broker.mqttgo.io
#   wss://mqttgo.io:8084/mqtt   (secure, for https / production)
#   ws://mqttgo.io:8000/mqtt    (plain, for http://localhost dev)
# Local Mosquitto: ws://YOUR_LAN_IP:8083/mqtt
VITE_MQTT_WS_URL=wss://mqttgo.io:8084/mqtt

# Optional auth (leave empty if broker allows anonymous)
# VITE_MQTT_USER=
# VITE_MQTT_PASS=

# Topics (defaults match robotic_dashboard_mqtt.ino)
# VITE_TOPIC_TELEMETRY=robotic/dashboard/telemetry
# VITE_TOPIC_COMMAND=robotic/dashboard/command
